{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "database/**"
    ],
    "headers": [
      {
        "source": "/database/**",
        "headers": [{ "key": "Cache-Control", "value": "no-store" }]
      }
    ],
    "rewrites": [
      { "source": "/database/**", "destination": "/404.html" }
    ]
  }
}