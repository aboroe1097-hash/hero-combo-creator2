rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function validComment() {
      return request.resource.data.keys().hasOnly([
        'text', 'name', 'parentId', 'authorId', 'createdAt', 'approved', 'public'
      ])
      && request.resource.data.text is string
      && request.resource.data.text.size() > 0
      && request.resource.data.text.size() <= 2000
      && request.resource.data.authorId == request.auth.uid
      && request.resource.data.approved == false
      && request.resource.data.public == true;
    }

    function isReadableComment() {
      return resource.data.approved == true
        && resource.data.public == true;
    }

    function canReadComment() {
      return signedIn()
        && (isReadableComment()
          || resource.data.authorId == request.auth.uid
          || isAdmin());
    }

    function validUserProfile() {
      return request.resource.data.keys().hasOnly(['playerProfile'])
      && request.resource.data.playerProfile is map
      && request.resource.data.playerProfile.keys().hasOnly(['roster'])
      && request.resource.data.playerProfile.roster is list
      && request.resource.data.playerProfile.roster.size() <= 120;
    }

    function validBestCombo() {
      return request.resource.data.keys().hasOnly(['heroes', 'timestamp'])
      && request.resource.data.heroes is list
      && request.resource.data.heroes.size() == 3
      && request.resource.data.heroes[0] is string
      && request.resource.data.heroes[1] is string
      && request.resource.data.heroes[2] is string
      && request.resource.data.heroes[0].size() <= 80
      && request.resource.data.heroes[1].size() <= 80
      && request.resource.data.heroes[2].size() <= 80
      && request.resource.data.timestamp is timestamp;
    }

    function validClientError() {
      return request.resource.data.keys().hasOnly([
        'source', 'error', 'extra', 'path', 'userAgent', 'createdAt', 'authorId', 'receivedAt'
      ])
      && request.resource.data.source is string
      && request.resource.data.source.size() > 0
      && request.resource.data.source.size() <= 120
      && request.resource.data.error is map
      && request.resource.data.error.keys().hasOnly(['name', 'message', 'stack'])
      && request.resource.data.error.name is string
      && request.resource.data.error.name.size() <= 120
      && request.resource.data.error.message is string
      && request.resource.data.error.message.size() <= 2000
      && request.resource.data.error.stack is string
      && request.resource.data.error.stack.size() <= 8000
      && request.resource.data.extra is map
      && request.resource.data.extra.keys().size() <= 12
      && request.resource.data.path is string
      && request.resource.data.path.size() <= 500
      && request.resource.data.userAgent is string
      && request.resource.data.userAgent.size() <= 500
      && request.resource.data.createdAt is string
      && request.resource.data.createdAt.size() <= 40
      && request.resource.data.authorId == request.auth.uid
      && request.resource.data.receivedAt == request.time;
    }

    function validSharedIntel() {
      return request.resource.data.keys().hasOnly(['guilds', 'status', 'updatedAt', 'updatedBy'])
      && (!('guilds' in request.resource.data) || request.resource.data.guilds is map)
      && (!('status' in request.resource.data) || request.resource.data.status is map)
      && request.resource.data.updatedAt is timestamp
      && request.resource.data.updatedBy == 'eden-map-planner';
    }

    function validDashboardData() {
      return request.resource.data.keys().hasOnly([
        'last_updated', 'total_attacks', 'attacks', 'players_summary', 'logs',
        'bannerRecords', 'dutyRecords', 'contributionRecords'
      ])
      && (!('last_updated' in request.resource.data) || request.resource.data.last_updated is string)
      && (!('total_attacks' in request.resource.data) || request.resource.data.total_attacks is int)
      && (!('attacks' in request.resource.data) || request.resource.data.attacks is list)
      && (!('players_summary' in request.resource.data) || request.resource.data.players_summary is list)
      && (!('logs' in request.resource.data) || request.resource.data.logs is list)
      && (!('bannerRecords' in request.resource.data) || request.resource.data.bannerRecords is list)
      && (!('dutyRecords' in request.resource.data) || request.resource.data.dutyRecords is list)
      && (!('contributionRecords' in request.resource.data) || request.resource.data.contributionRecords is list);
    }

    function validRosterData() {
      return request.resource.data.keys().hasOnly(['snapshots', 'updated'])
      && request.resource.data.snapshots is list
      && request.resource.data.snapshots.size() <= 50
      && request.resource.data.updated is string;
    }

    function validConductAdjustment() {
      return request.resource.data.keys().hasOnly([
        'id', 'season', 'playerKey', 'playerName', 'points', 'category', 'note', 'createdAt', 'createdBy'
      ])
      && request.resource.data.id is string
      && request.resource.data.id.size() > 0
      && request.resource.data.id.size() <= 80
      && request.resource.data.season is string
      && request.resource.data.season.size() > 0
      && request.resource.data.season.size() <= 40
      && request.resource.data.playerKey is string
      && request.resource.data.playerKey.size() > 0
      && request.resource.data.playerKey.size() <= 120
      && request.resource.data.playerName is string
      && request.resource.data.playerName.size() > 0
      && request.resource.data.playerName.size() <= 120
      && request.resource.data.points is int
      && request.resource.data.points >= -10000000
      && request.resource.data.points <= 10000000
      && request.resource.data.category in [
        'banner_help', 'connected_road', 'extra_effort', 'merit_other',
        'path_block', 'toxicity', 'ignored_coordination', 'penalty_other'
      ]
      && request.resource.data.note is string
      && request.resource.data.note.size() <= 500
      && request.resource.data.createdAt is timestamp
      && request.resource.data.createdBy is string
      && request.resource.data.createdBy.size() > 0
      && request.resource.data.createdBy.size() <= 128;
    }

    match /comments/{commentId} {
      allow read: if canReadComment();
      allow create: if signedIn() && validComment();
      allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && validUserProfile();
      allow delete: if false;

      match /bestCombos/{comboId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && validBestCombo();
        allow update: if false;
        allow delete: if isOwner(uid);
      }
    }

    match /errors/{errorId} {
      allow read, delete: if isAdmin();
      allow create: if signedIn() && validClientError();
      allow update: if false;
    }

    match /eden_map/shared_intel {
      allow read: if signedIn();
      allow create, update: if isAdmin() && validSharedIntel();
      allow delete: if false;
    }

    match /vts_admin/dashboard_data {
      allow read: if signedIn();
      allow create, update: if isAdmin() && validDashboardData();
      allow delete: if false;
    }

    match /vts_admin/roster_data {
      allow read: if signedIn();
      allow create, update: if isAdmin() && validRosterData();
      allow delete: if false;
    }

    match /vts_admin/conduct_adjustments/records/{adjustmentId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && validConductAdjustment()
        && request.resource.data.id == adjustmentId
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin()
        && validConductAdjustment()
        && request.resource.data.id == adjustmentId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /vts_admin/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
