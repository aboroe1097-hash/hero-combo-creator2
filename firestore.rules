rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function validComment() {
      return request.resource.data.keys().hasOnly([
        'text', 'name', 'email', 'parentId', 'authorId', 'createdAt', 'approved', 'public'
      ])
      && request.resource.data.text is string
      && request.resource.data.text.size() > 0
      && request.resource.data.text.size() <= 2000
      && request.resource.data.authorId == request.auth.uid
      && request.resource.data.approved == true
      && request.resource.data.public == true;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn() && validComment();
      allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /users/{uid} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;

      match /bestCombos/{comboId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /eden_map/shared_intel {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /vts_admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
