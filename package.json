  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^6.3.5"
  }
