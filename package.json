{
  "name": "hero-combo-creator",
  "private": true,
  "type": "module",
  "scripts": {
    "build:eden": "python database/build-eden-datasets.py",
    "dev": "vite",
    "build": "npm run build:eden && vite build && node scripts/post-build.mjs",
