const englishTranslationKeys = Object.keys(translations.en);

for (const [lang, values] of Object.entries(translations)) {
  const missingBeforeFallback = englishTranslationKeys.filter(key => !(key in values));
  translationCoverage[lang] = {
    total: englishTranslationKeys.length,
    provided: englishTranslationKeys.length - missingBeforeFallback.length,
    missingBeforeFallback
  };

  if (lang !== 'en') {
    for (const key of missingBeforeFallback) {
      values[key] = translations.en[key];
    }
  }
