import { createHotContext as __vite__createHotContext } from "/@vite/client";import.meta.hot = __vite__createHotContext("/css/mobile.css");import { updateStyle as __vite__updateStyle, removeStyle as __vite__removeStyle } from "/@vite/client"
const __vite__id = "D:/Project/hero-combo-creator2/css/mobile.css"
const __vite__css = "/* =============================================================\r\n   mobile.css — VTS Hero Combo Tool\r\n   Applied on screens ≤768px via <link media=\"(max-width: 768px)\">\r\n\r\n   UPGRADE PHILOSOPHY:\r\n   — Finger-first: every interactive target ≥44px\r\n   — Spatial zones: safe areas, inset-bottom, notch aware\r\n   — Fluid type: rem-based scale, not px overrides\r\n   — Momentum scroll everywhere it should scroll\r\n   — No layout jank: fixed heights only where truly needed\r\n   — Light theme fully covered, not just dark\r\n   ============================================================= */\r\n\r\n/* ── 0. DESIGN TOKENS (mobile overrides) ──────────────────── */\r\n:root {\r\n  --mobile-gap:     8px;\r\n  --mobile-radius:  12px;\r\n  --tap-min:        44px;      /* minimum touch target */\r\n  --nav-h:          52px;      /* tab bar height */\r\n  --footer-h:       80px;      /* sticky combo footer */\r\n  --safe-bottom:    env(safe-area-inset-bottom, 0px);\r\n  --safe-top:       env(safe-area-inset-top, 0px);\r\n  --safe-left:      env(safe-area-inset-left, 0px);\r\n  --safe-right:     env(safe-area-inset-right, 0px);\r\n}\r\n\r\n/* ── 1. BASE ──────────────────────────────────────────────── */\r\nhtml {\r\n  -webkit-text-size-adjust: 100%;\r\n  -moz-text-size-adjust: 100%;\r\n       text-size-adjust: 100%;\r\n  /* Use dynamic viewport on supporting browsers */\r\n  height: -webkit-fill-available;\r\n}\r\n\r\nbody {\r\n  min-height: -webkit-fill-available;\r\n  overscroll-behavior-y: none;\r\n  padding-bottom: calc(24px + var(--safe-bottom)) !important;\r\n  /* Prevent double-tap zoom on UI */\r\n  touch-action: manipulation;\r\n}\r\n\r\n/* Only add footer clearance when sticky bar is visible */\r\nbody.tab-manual-active {\r\n  padding-bottom: calc(var(--footer-h) + var(--safe-bottom) + 16px) !important;\r\n}\r\n\r\n/* Kill tap highlight globally but keep focus ring for a11y */\r\n* { -webkit-tap-highlight-color: transparent; }\r\n:focus-visible { outline: 2px solid #3b82f6; outline-offset: 2px; }\r\n\r\n/* ── 2. APP SHELL ─────────────────────────────────────────── */\r\n#app {\r\n  padding: 8px !important;\r\n  border-radius: var(--mobile-radius) !important;\r\n  /* Prevent horizontal overflow from any child */\r\n  overflow-x: clip;\r\n}\r\n\r\n/* ── 3. BRANDING / SPLASH ─────────────────────────────────── */\r\n.team-badge,\r\n#createComboTitle { display: none !important; }\r\n\r\n#appTitle { font-size: 1.55rem !important; line-height: 1.15 !important; }\r\n.main-logo { width: 96px !important; height: 96px !important; }\r\n.logo-container { margin-bottom: 1rem !important; }\r\n\r\n/* Boot splash — mobile proportions */\r\n.perspective-container {\r\n  width: 100vw !important;\r\n  height: 100vh !important;\r\n  aspect-ratio: auto;\r\n  perspective: 1000px;\r\n}\r\n.boot-brand { font-size: 0.92rem !important; }\r\n.boot-logo  { width: 72px !important; height: 72px !important; }\r\n.boot-logo-orbit { width: 90px !important; height: 90px !important; }\r\n.intro-logo { width: 88px !important; height: 88px !important; }\r\n.intro-enter-btn { padding: 10px 20px !important; font-size: 0.64rem !important; }\r\n\r\n/* ── 4. TAB NAV ───────────────────────────────────────────── */\r\n#tabNavScroll {\r\n  overflow-x: auto !important;\r\n  overflow-y: hidden !important;\r\n  -webkit-overflow-scrolling: touch !important;\r\n  scrollbar-width: none !important;\r\n  flex-wrap: nowrap !important;\r\n  padding: 3px 4px !important;\r\n  gap: 2px !important;\r\n  /* Subtle edge fade to hint scrollability */\r\n  -webkit-mask-image: linear-gradient(\r\n    to right,\r\n    transparent 0px, black 10px,\r\n    black calc(100% - 10px), transparent 100%\r\n  );\r\n  mask-image: linear-gradient(\r\n    to right,\r\n    transparent 0px, black 10px,\r\n    black calc(100% - 10px), transparent 100%\r\n  );\r\n  /* Glass surface */\r\n  background: rgba(15, 23, 42, 0.78) !important;\r\n  backdrop-filter: blur(14px) !important;\r\n  -webkit-backdrop-filter: blur(14px) !important;\r\n  border: 1px solid rgba(255,255,255,0.07) !important;\r\n}\r\n#tabNavScroll::-webkit-scrollbar { display: none; }\r\n#tabNavScroll > div { flex: 0 0 auto !important; width: auto !important; }\r\n\r\n.tab-pill {\r\n  font-size: 0.67rem !important;\r\n  padding: 0.42rem 0.6rem !important;\r\n  white-space: nowrap !important;\r\n  gap: 3px !important;\r\n  min-height: var(--tap-min) !important;\r\n  display: flex !important;\r\n  align-items: center !important;\r\n}\r\n.tab-pill svg { width: 11px !important; height: 11px !important; }\r\n\r\n.tab-badge-wrap { padding-top: 6px !important; margin-right: 4px !important; }\r\n.tab-badge {\r\n  z-index: 20 !important;\r\n  top: 0 !important;\r\n  right: -1px !important;\r\n  font-size: 6.5px !important;\r\n  padding: 1px 3px !important;\r\n  transform: translateY(0) scale(0.9) !important;\r\n  letter-spacing: 0.03em !important;\r\n}\r\n\r\n/* Light-theme tab nav */\r\n[data-theme=\"light\"] #tabNavScroll {\r\n  background: rgba(248,250,252,0.88) !important;\r\n  border-color: rgba(0,0,0,0.07) !important;\r\n}\r\n\r\n/* ── 5. GLOBAL CONTROLS ───────────────────────────────────── */\r\n#globalToggleRow { margin-bottom: 8px !important; }\r\n#globalToggleRow label { padding: 7px 10px !important; gap: 7px !important; }\r\n#globalToggleRow span { font-size: 0.56rem !important; }\r\n\r\n/* Filter pills — scrollable row, no wrap */\r\n.filter-pill {\r\n  font-size: 0.7rem !important;\r\n  padding: 6px 10px !important;\r\n  min-height: var(--tap-min) !important;\r\n  flex-shrink: 0;\r\n}\r\n\r\n/* Let filter rows wrap naturally to prevent screen stretching */\r\n#seasonFilters, #stateFilters, #troopFilters,\r\n#generatorSeasonFilters, #generatorStateFilters, #generatorTroopFilters {\r\n  flex-wrap: wrap !important;\r\n  justify-content: center;\r\n}\r\n\r\n#manualSection .mb-6, #generatorSection .mb-6 {\r\n  padding: 10px !important;\r\n  margin-bottom: 12px !important;\r\n}\r\n#genSelectTitle, #availableHeroesTitle {\r\n  font-size: 0.95rem !important;\r\n}\r\n\r\n/* ── 6. HERO GRID ─────────────────────────────────────────── */\r\n#generatorHeroes, #availableHeroes {\r\n  grid-template-columns: repeat(4, 1fr) !important;\r\n  gap: 5px !important;\r\n  padding: 0 !important;\r\n}\r\n\r\n/* 3-col fallback for very narrow screens handled in @480 block */\r\n.hero-card, .generator-card {\r\n  width: 100% !important;\r\n  min-width: 0 !important;\r\n  min-height: 0 !important;\r\n  aspect-ratio: 1 / 1.28;\r\n  padding: 5px !important;\r\n  margin: 0 !important;\r\n  /* Spring feedback on tap */\r\n  transition: transform 0.12s cubic-bezier(0.25, 1, 0.5, 1) !important;\r\n}\r\n.hero-card:active, .generator-card:active {\r\n  transform: scale(0.93) !important;\r\n}\r\n\r\n.hero-card img, .generator-card img {\r\n  width: 46px !important;\r\n  height: 46px !important;\r\n  margin-bottom: 2px !important;\r\n}\r\n.generator-card.skin-animated-portrait::before {\r\n  top: 31px !important;\r\n  width: 28px !important;\r\n  height: 6px !important;\r\n}\r\n.generator-card.skin-animated-portrait img {\r\n  box-shadow: 0 0 10px rgba(251,191,36,0.2), 0 0 0 2px rgba(245,158,11,0.1) !important;\r\n}\r\n.generator-card.skin-priority-muted {\r\n  opacity: 0.54 !important;\r\n}\r\n.generator-card.generator-card-selected.skin-priority-muted {\r\n  opacity: 0.88 !important;\r\n}\r\n\r\n/* Prevent info-btn from overlapping the paid-badge on mobile */\r\n.hero-card:has(.paid-badge) .info-btn { top: 26px !important; }\r\n\r\n.hero-card span.text-xs, .generator-card span.text-xs {\r\n  font-size: 0.55rem !important;\r\n  line-height: 1.1 !important;\r\n  white-space: normal !important;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.hero-tag {\r\n  font-size: 0.44rem !important;\r\n  padding: 1px 3px !important;\r\n  top: 2px !important;\r\n  left: 2px !important;\r\n}\r\n\r\n.generator-card-selected {\r\n  border: 2px solid #38bdf8 !important;\r\n  transform: scale(0.92) !important;\r\n  box-shadow: 0 0 12px rgba(56,189,248,0.35) !important;\r\n}\r\n\r\n/* Paid badge on card */\r\n.paid-badge {\r\n  top: 3px !important;\r\n  right: 3px !important;\r\n  padding: 2px 4px 2px 2px !important;\r\n}\r\n.paid-badge--card .paid-gem-svg { width: 8px !important; height: 8px !important; }\r\n.paid-badge-text { font-size: 0.4rem !important; }\r\n\r\n/* ── 7. STICKY COMBO FOOTER (Manual Builder) ──────────────── */\r\n#comboFooterBar {\r\n  position: fixed !important;\r\n  bottom: 0 !important;\r\n  left: 0 !important;\r\n  right: 0 !important;\r\n  width: 100% !important;\r\n  z-index: 110 !important;\r\n  border-radius: 16px 16px 0 0 !important;\r\n  padding: 10px 12px calc(10px + var(--safe-bottom)) !important;\r\n  box-shadow: 0 -6px 28px rgba(0,0,0,0.65) !important;\r\n  /* Above content, below any modals */\r\n}\r\n\r\n.combo-slot {\r\n  width: 66px !important;\r\n  height: 66px !important;\r\n  margin: 0 !important;\r\n  border-width: 2px !important;\r\n  border-radius: 10px !important;\r\n}\r\n\r\n#comboButtonsRow {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, 1fr);\r\n  gap: 6px;\r\n  margin-top: 8px;\r\n}\r\n#comboButtonsRow button {\r\n  font-size: 0.69rem !important;\r\n  padding: 0 8px !important;\r\n  min-height: var(--tap-min) !important;\r\n  border-radius: 10px !important;\r\n  touch-action: manipulation;\r\n}\r\n\r\n/* ── 8. GENERATOR BUTTONS ─────────────────────────────────── */\r\n#generateCombosBtn, #generateRandomBtn, #downloadGeneratorBtn {\r\n  display: block;\r\n  width: 100%;\r\n  margin: 4px auto;\r\n  border-radius: 9999px;\r\n  font-size: 0.82rem;\r\n  font-weight: 800;\r\n  min-height: var(--tap-min);\r\n  padding: 0 16px;\r\n  letter-spacing: 0.04em;\r\n  touch-action: manipulation;\r\n}\r\n#generateCombosBtn {\r\n  background: linear-gradient(135deg, #15803d, #22c55e);\r\n  box-shadow: 0 3px 14px rgba(34,197,94,0.28);\r\n}\r\n#generateRandomBtn {\r\n  background: linear-gradient(135deg, #b45309, #f59e0b);\r\n  box-shadow: 0 3px 14px rgba(245,158,11,0.28);\r\n}\r\n#downloadGeneratorBtn {\r\n  background: linear-gradient(135deg, #6d28d9, #8b5cf6);\r\n  box-shadow: 0 3px 14px rgba(139,92,246,0.28);\r\n}\r\n\r\n/* ── 9. SAVED / GENERATED COMBOS ─────────────────────────── */\r\n.saved-combo-display {\r\n  padding: 10px 10px 10px 50px !important;\r\n  margin: 5px 0 !important;\r\n  width: 100% !important;\r\n  box-sizing: border-box !important;\r\n  min-height: 100px !important;\r\n}\r\n.saved-combo-number {\r\n  left: 9px !important;\r\n  width: 27px !important;\r\n  height: 27px !important;\r\n  font-size: 0.72rem !important;\r\n}\r\n\r\n.generated-combo-card {\r\n  flex-direction: column !important;\r\n  align-items: center !important;\r\n  padding: 14px 10px 10px 10px !important;\r\n  gap: 8px !important;\r\n  min-height: 0 !important;\r\n}\r\n.generated-combo-card .saved-combo-number {\r\n  top: 10px !important;\r\n  left: 10px !important;\r\n  transform: none !important;\r\n}\r\n.generated-combo-card .saved-combo-slots {\r\n  display: flex !important;\r\n  flex-direction: row !important;\r\n  justify-content: center !important;\r\n  gap: 6px !important;\r\n  width: 100% !important;\r\n  overflow-x: auto !important;\r\n  -webkit-overflow-scrolling: touch;\r\n}\r\n.generated-combo-card .gen-score-panel {\r\n  margin-left: 0 !important;\r\n  text-align: center !important;\r\n}\r\n\r\n.saved-combo-display .saved-combo-slots {\r\n  gap: 6px !important;\r\n  flex-wrap: wrap !important;\r\n}\r\n.saved-combo-display .saved-combo-slot-item,\r\n.generated-combo-card .saved-combo-slot-item {\r\n  width: 76px !important;\r\n  height: 76px !important;\r\n}\r\n.saved-combo-slot-item img {\r\n  width: 72px !important;\r\n  height: 72px !important;\r\n}\r\n\r\n/* ── 10. HERO ATLAS TAB ───────────────────────────────────── */\r\n#heroesSection,\r\n#heroesTabContent,\r\n.heroes-tab-inner,\r\n.heroes-toolbar-sticky {\r\n  width: 100% !important;\r\n  max-width: 100% !important;\r\n  min-width: 0 !important;\r\n  overflow-x: clip;\r\n}\r\n\r\n.heroes-toolbar-sticky {\r\n  top: 0 !important;\r\n  padding-bottom: 4px !important;\r\n  z-index: 40;\r\n}\r\n.heroes-toolbar {\r\n  padding: 7px 8px !important;\r\n  gap: 5px !important;\r\n}\r\n\r\n/* Season + filter pill rows — horizontal scroll */\r\n.heroes-season-tabs,\r\n.heroes-filter-pills {\r\n  display: flex !important;\r\n  flex-wrap: nowrap !important;\r\n  overflow-x: auto !important;\r\n  -webkit-overflow-scrolling: touch;\r\n  scrollbar-width: none;\r\n  gap: 4px !important;\r\n  padding: 5px 6px !important;\r\n}\r\n.heroes-season-tabs::-webkit-scrollbar,\r\n.heroes-filter-pills::-webkit-scrollbar { display: none; }\r\n\r\n.hero-tab-season {\r\n  flex-shrink: 0;\r\n  padding: 6px 12px !important;\r\n  font-size: 0.67rem !important;\r\n  min-height: 34px;\r\n}\r\n.heroes-filter-pill {\r\n  flex-shrink: 0 !important;\r\n  padding: 6px 10px !important;\r\n  font-size: 0.62rem !important;\r\n  min-height: 32px;\r\n}\r\n.heroes-count-badge { font-size: 0.6rem !important; padding: 2px 7px !important; }\r\n.heroes-clear-filters { font-size: 0.58rem !important; }\r\n\r\n/* Detail panel: full-width bottom sheet on mobile */\r\n.heroes-layout.has-detail { flex-direction: column !important; gap: 8px !important; }\r\n.heroes-layout.has-detail .heroes-ranking-list { display: none !important; }\r\n.heroes-layout.has-detail .hero-detail-panel {\r\n  width: 100% !important;\r\n  max-height: none !important;\r\n  position: relative !important;\r\n  top: auto !important;\r\n  border: 1.5px solid rgba(99,102,241,0.3) !important;\r\n}\r\n\r\n/* Ranking list — constrained scroll */\r\n.heroes-layout:not(.has-detail) .heroes-ranking-list {\r\n  width: 100% !important;\r\n  max-width: 100% !important;\r\n  max-height: 68vh !important;\r\n  overflow-y: auto !important;\r\n  -webkit-overflow-scrolling: touch;\r\n  border-radius: 12px;\r\n  padding: 3px;\r\n}\r\n\r\n/* Back button visible; desktop close hidden */\r\n.heroes-mobile-back { display: block !important; }\r\n.detail-close { display: none !important; }\r\n\r\n/* Hide filters when detail is open */\r\n.heroes-tab-inner--detail-open .heroes-filter-pills,\r\n.heroes-tab-inner--detail-open .heroes-season-tabs,\r\n.heroes-tab-inner--detail-open .heroes-toolbar { display: none !important; }\r\n.heroes-tab-inner--detail-open .heroes-toolbar-sticky {\r\n  background: transparent !important;\r\n  backdrop-filter: none !important;\r\n  padding-bottom: 0 !important;\r\n}\r\n\r\n/* Ranking rows */\r\n.hero-rank-row {\r\n  padding: 9px 10px !important;\r\n  gap: 7px !important;\r\n  min-height: var(--tap-min) !important;\r\n}\r\n.rank-medal     { font-size: 1.25rem !important; min-width: 32px !important; }\r\n.rank-medal--num { font-size: 1.05rem !important; min-width: 32px !important; padding: 3px 2px !important; }\r\n.rank-img       { width: 34px !important; height: 34px !important; }\r\n.rank-name      { font-size: 0.78rem !important; }\r\n.rank-score     { font-size: 0.82rem !important; min-width: 26px !important; }\r\n\r\n/* Detail panel internals */\r\n.hero-detail-panel { padding: 14px 12px !important; border-radius: 14px !important; }\r\n.detail-header { flex-wrap: wrap; gap: 8px !important; }\r\n.detail-img { width: 60px !important; height: 60px !important; }\r\n.detail-name { font-size: 0.95rem !important; line-height: 1.25 !important; }\r\n.detail-stats-row { grid-template-columns: repeat(2, 1fr) !important; gap: 5px !important; }\r\n.detail-stat { padding: 7px 5px !important; }\r\n.detail-stat-val { font-size: 0.82rem !important; }\r\n\r\n.detail-combo-row { padding: 8px 10px !important; gap: 6px !important; }\r\n.detail-combo-hero { padding: 5px 3px 4px !important; }\r\n.detail-combo-hero img { width: 40px !important; height: 40px !important; }\r\n.detail-combo-hero span { font-size: 0.55rem !important; }\r\n.detail-combo-score { font-size: 0.9rem !important; }\r\n.detail-combo-rank { font-size: 0.65rem !important; }\r\n\r\n/* Combo counters in detail */\r\n.combo-counters-inline { margin-top: 4px; padding: 0.4rem 0.5rem !important; }\r\n.counter-toggle-btn { font-size: 0.55rem !important; padding: 4px 8px !important; }\r\n.counter-hero-chip { padding: 3px 2px !important; }\r\n.counter-hero-chip-name { font-size: 0.46rem !important; }\r\n.counter-hero-chip-img { width: 24px !important; height: 24px !important; }\r\n.counter-card-reason { font-size: 0.53rem !important; }\r\n.counter-use-btn {\r\n  width: 100% !important;\r\n  min-height: 34px !important;\r\n  font-size: 0.55rem !important;\r\n}\r\n.counter-summary-badge {\r\n  font-size: 0.48rem !important;\r\n  padding: 2px 6px !important;\r\n}\r\n.hero-counter-section-grid {\r\n  grid-template-columns: 1fr !important;\r\n  gap: 8px !important;\r\n}\r\n.hero-counter-column {\r\n  padding: 8px !important;\r\n}\r\n.counter-matchup-grid {\r\n  grid-template-columns: 1fr !important;\r\n  gap: 6px !important;\r\n}\r\n.counter-matchup-vs {\r\n  text-align: center !important;\r\n}\r\n.counter-matchup-card {\r\n  padding: 8px !important;\r\n}\r\n.counter-matchup-side {\r\n  padding: 6px !important;\r\n}\r\n\r\n/* ── 11. RESEARCH TAB ─────────────────────────────────────── */\r\n#researchSection,\r\n.research-control-deck,\r\n.research-list {\r\n  width: 100% !important;\r\n  max-width: 100% !important;\r\n  min-width: 0 !important;\r\n  overflow-x: clip;\r\n}\r\n\r\n.research-header { flex-direction: column; gap: 6px !important; margin-bottom: 10px !important; }\r\n.research-title { font-size: 1.1rem !important; }\r\n.research-desc { font-size: 0.72rem !important; }\r\n.research-tree-count { align-self: flex-start; font-size: 0.58rem !important; padding: 3px 9px !important; }\r\n.research-control-deck { gap: 5px !important; margin-bottom: 10px !important; }\r\n.research-deck-row {\r\n  padding: 7px 9px !important;\r\n  gap: 5px 7px !important;\r\n  flex-wrap: nowrap !important;\r\n  overflow-x: auto !important;\r\n  -webkit-overflow-scrolling: touch;\r\n  scrollbar-width: none;\r\n}\r\n.research-deck-row::-webkit-scrollbar { display: none; }\r\n.research-deck-label { font-size: 0.52rem !important; min-width: 36px !important; }\r\n.research-season-segment { padding: 2px !important; }\r\n.research-season-bar {\r\n  flex-wrap: nowrap !important;\r\n  overflow-x: auto !important;\r\n  -webkit-overflow-scrolling: touch;\r\n  scrollbar-width: none;\r\n}\r\n.research-season-bar::-webkit-scrollbar { display: none; }\r\n.tech-season-btn { flex-shrink: 0; padding: 6px 10px !important; font-size: 0.66rem !important; min-height: 32px; }\r\n.research-quick-segment { width: 100%; }\r\n.research-quick-btn { flex: 1; font-size: 0.62rem !important; padding: 7px 9px !important; min-height: var(--tap-min); }\r\n.research-search-wrap { max-width: 100% !important; flex: 1 1 100% !important; width: 100% !important; }\r\n.research-search-input { font-size: 0.74rem !important; min-height: 38px; }\r\n.research-branch-segment { margin: 10px auto 16px !important; padding: 3px !important; }\r\n.research-branch-btn { padding: 8px 4px !important; font-size: 0.54rem !important; min-height: 36px; }\r\n.research-branch-btn span:first-child { font-size: 0.95rem !important; }\r\n.research-calc-title { font-size: 0.95rem !important; }\r\n.research-calc-actions { gap: 5px !important; }\r\n.research-calc-btn { font-size: 0.6rem !important; padding: 7px 9px !important; min-height: var(--tap-min); }\r\n\r\n/* Game-style tech tree */\r\n.research-game-tree-viewport { max-height: none !important; padding: 10px 6px 4px !important; }\r\n.game-tech-medallion { width: 72px !important; height: 80px !important; }\r\n.game-tech-core { width: 58px !important; height: 64px !important; }\r\n.game-tech-icon-svg { width: 20px !important; height: 20px !important; }\r\n.game-tech-level-badge { font-size: 0.46rem !important; min-width: 30px !important; }\r\n.game-tech-stepper, .game-tech-cost-pill { max-width: 100% !important; }\r\n.game-tech-step { padding: 5px 0 !important; font-size: 0.76rem !important; }\r\n.game-tech-step--max { font-size: 0.48rem !important; }\r\n.game-tech-name { font-size: 0.5rem !important; max-width: 78px !important; }\r\n.game-tree-tier { gap: 7px !important; }\r\n.research-page-tab { font-size: 0.54rem !important; padding: 5px 8px !important; min-height: 30px; }\r\n.research-game-title { font-size: 0.85rem !important; }\r\n\r\n/* Research card grid — 3 cols on mobile */\r\n.research-grid {\r\n  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;\r\n  gap: 6px !important;\r\n}\r\n.research-tech-card { padding: 6px !important; border-radius: 8px !important; }\r\n.research-card-title { font-size: 0.65rem !important; }\r\n.research-card-unlock { font-size: 0.5rem !important; }\r\n.research-card-cta { font-size: 0.5rem !important; padding: 5px 4px !important; min-height: 28px !important; }\r\n.research-card-resource { font-size: 0.65rem !important; margin-right: 4px !important; }\r\n.research-card-icon { width: 12px !important; height: 12px !important; }\r\n.research-card-head { margin-bottom: 4px !important; padding-right: 28px !important; }\r\n.research-card-progress { gap: 4px !important; }\r\n.research-card-max { padding: 2px 4px !important; font-size: 0.5rem !important; }\r\n\r\n/* Summary / totals */\r\n.research-summary-card { padding: 10px !important; }\r\n.research-summary-title { font-size: 0.75rem !important; }\r\n.research-summary-pct { font-size: 0.92rem !important; }\r\n.research-summary-stat-value { font-size: 0.96rem !important; }\r\n.research-medal-icon { width: 14px !important; height: 14px !important; }\r\n.research-calculator { padding: 10px !important; border-radius: 12px !important; margin-top: 10px !important; }\r\n\r\n/* Legacy tech calculator IDs */\r\n#techCalculatorContainer { padding: 10px !important; border-radius: 12px !important; }\r\n#techCalculatorContainer #closeCalcBtn { padding: 8px !important; min-width: var(--tap-min); min-height: var(--tap-min); }\r\n#techCalculatorContainer #resetAllTechBtn,\r\n#techCalculatorContainer #maxAllTechBtn { font-size: 0.62rem !important; padding: 7px 5px !important; min-height: var(--tap-min); }\r\n#techCalculatorContainer .overflow-x-hidden { max-height: 52vh !important; border-radius: 8px !important; }\r\n\r\n.tech-node-slider { height: 5px !important; }\r\n.tech-node-slider::-webkit-slider-thumb { width: 18px !important; height: 18px !important; }\r\n.tech-node-input { width: 34px !important; font-size: 0.73rem !important; padding: 2px 0 !important; }\r\n.tech-node-container .flex.justify-between.gap-1 { gap: 3px !important; flex-wrap: wrap !important; }\r\n.quick-set-btn { padding: 4px 5px !important; font-size: 0.6rem !important; flex: 1 !important; min-width: 26px !important; border-radius: 5px !important; min-height: 30px; }\r\n.branch-tab-btn { font-size: 0.6rem !important; padding: 7px 4px !important; border-radius: 8px !important; min-height: var(--tap-min); }\r\n.branch-tab-btn span:first-child { font-size: 0.95rem !important; }\r\n\r\n/* Research global summary */\r\n#globalTechSummary > div { padding: 10px !important; border-radius: 10px !important; }\r\n#globalTechSummary h3 { font-size: 0.76rem !important; }\r\n#globalTechSummary .text-base { font-size: 0.82rem !important; }\r\n#globalTechSummary .text-3xl { font-size: 1.05rem !important; }\r\n#globalTechSummary > div > div.grid { grid-template-columns: 1fr 1fr; gap: 6px; }\r\n#globalTechSummary .bg-slate-950\\/60 { padding: 9px !important; border-radius: 7px !important; }\r\n#globalTechSummary .h-5 { height: 8px !important; }\r\n\r\n#totalTechCost span {\r\n  font-size: 0.88rem !important;\r\n  padding: 7px 9px !important;\r\n  gap: 7px !important;\r\n  border-radius: 7px !important;\r\n  width: 100% !important;\r\n}\r\n#totalTechCost span img { width: 13px !important; height: 13px !important; }\r\n\r\n/* ── 12. EDEN MAP TAB ─────────────────────────────────────── */\r\n.eden-map-root { gap: 5px !important; }\r\n.eden-map-header > div:first-child h2 { font-size: 1.1rem !important; letter-spacing: 0.07em !important; }\r\n.eden-map-header > div:first-child p { font-size: 0.7rem !important; line-height: 1.3 !important; }\r\n.eden-map-body { flex-direction: column !important; gap: 0 !important; }\r\n\r\n/* Canvas — fill available width, fixed min height */\r\n.eden-canvas-wrap {\r\n  min-height: min(50vh, 380px) !important;\r\n  touch-action: none;\r\n  -webkit-user-select: none;\r\n  -moz-user-select: none;\r\n       user-select: none;\r\n}\r\n#edenMapCanvas { min-height: min(50vh, 380px) !important; }\r\n\r\n/* All toolbars — horizontal scroll, no wrap */\r\n.eden-control-deck { gap: 5px !important; }\r\n.eden-deck-row,\r\n.eden-toolbar-primary,\r\n.eden-toolbar-tools,\r\n.eden-toolbar-modes,\r\n.eden-deck-nav,\r\n.eden-deck-tools,\r\n.eden-deck-meta,\r\n.eden-layer-bar,\r\n.eden-quick-jump,\r\n.eden-layer-scroll,\r\n.eden-quick-scroll {\r\n  padding: 6px 8px !important;\r\n  gap: 5px !important;\r\n  flex-wrap: nowrap !important;\r\n  overflow-x: auto !important;\r\n  -webkit-overflow-scrolling: touch;\r\n  scrollbar-width: none;\r\n}\r\n.eden-deck-row::-webkit-scrollbar,\r\n.eden-toolbar-primary::-webkit-scrollbar,\r\n.eden-toolbar-tools::-webkit-scrollbar,\r\n.eden-toolbar-modes::-webkit-scrollbar,\r\n.eden-deck-nav::-webkit-scrollbar,\r\n.eden-deck-tools::-webkit-scrollbar,\r\n.eden-deck-meta::-webkit-scrollbar,\r\n.eden-layer-bar::-webkit-scrollbar,\r\n.eden-quick-jump::-webkit-scrollbar,\r\n.eden-layer-scroll::-webkit-scrollbar,\r\n.eden-quick-scroll::-webkit-scrollbar { display: none; }\r\n\r\n.eden-deck-label { min-width: 34px !important; font-size: 0.5rem !important; }\r\n.eden-toolbar-spacer { display: none !important; }\r\n.eden-toolbar-divider { height: 20px !important; margin: 0 2px !important; flex-shrink: 0; }\r\n\r\n/* Touch-friendly tool buttons */\r\n.eden-tool-btn {\r\n  padding: 8px 10px !important;\r\n  font-size: 0.62rem !important;\r\n  min-height: var(--tap-min) !important;\r\n  min-width: var(--tap-min) !important;\r\n  flex-shrink: 0;\r\n  white-space: nowrap;\r\n}\r\n.eden-tool-icon { min-width: var(--tap-min) !important; min-height: var(--tap-min) !important; padding: 8px !important; }\r\n\r\n.eden-sector-select,\r\n.eden-plan-select,\r\n.eden-view-select,\r\n.eden-path-color-select { font-size: 0.62rem !important; min-height: 36px; flex-shrink: 0; }\r\n.eden-plan-select { min-width: 92px !important; max-width: 120px !important; }\r\n.eden-path-label-input { width: 82px !important; min-height: 34px; font-size: 0.6rem !important; flex-shrink: 0; }\r\n\r\n.eden-layer-btn {\r\n  font-size: 0.58rem !important;\r\n  padding: 6px 8px !important;\r\n  min-height: 28px;\r\n  flex-shrink: 0;\r\n}\r\n.eden-ref-opacity input[type=\"range\"] { width: 60px !important; }\r\n\r\n/* Plans panel */\r\n.eden-plans-panel summary { padding: 8px 10px !important; font-size: 0.6rem !important; }\r\n.eden-plans-body { padding: 7px 9px 9px !important; flex-wrap: nowrap !important; overflow-x: auto !important; }\r\n.eden-path-tools.eden-path-tools--visible { flex-wrap: nowrap !important; overflow-x: auto !important; }\r\n\r\n/* Sidebar — bottom sheet */\r\n.eden-sidebar {\r\n  position: fixed !important;\r\n  left: 0; right: 0; bottom: 0;\r\n  z-index: 50;\r\n  width: 100% !important;\r\n  max-height: min(76vh, 600px) !important;\r\n  min-height: 0 !important;\r\n  overflow: hidden !important;\r\n  padding-bottom: var(--safe-bottom) !important;\r\n  transform: translateY(100%);\r\n  transition: transform 0.22s cubic-bezier(0.32, 0.72, 0, 1);\r\n  border-radius: 14px 14px 0 0 !important;\r\n  box-shadow: 0 -8px 28px rgba(0,0,0,0.5);\r\n}\r\n.eden-sidebar-list-section { flex: 1 1 auto !important; min-height: 0 !important; overflow-y: auto; }\r\n.eden-sidebar.eden-sidebar-open { transform: translateY(0); }\r\n.eden-sidebar-close {\r\n  display: flex !important;\r\n  align-items: center;\r\n  justify-content: center;\r\n  position: absolute; top: 8px; right: 10px;\r\n  width: 32px; height: 32px;\r\n  border-radius: 50%;\r\n  border: 1px solid rgba(71,85,105,0.8);\r\n  background: rgba(30,41,59,0.9);\r\n  color: #e2e8f0;\r\n  font-size: 1.1rem;\r\n  cursor: pointer;\r\n  z-index: 2;\r\n}\r\n\r\n/* HUD elements */\r\n.eden-coord-hud {\r\n  font-size: 0.56rem !important;\r\n  max-width: calc(100% - 110px) !important;\r\n  left: 5px !important;\r\n  top: 5px !important;\r\n  bottom: auto !important;\r\n  padding: 3px 6px !important;\r\n}\r\n\r\n.eden-map-legend {\r\n  display: flex !important;\r\n  flex-wrap: nowrap !important;\r\n  overflow-x: auto !important;\r\n  gap: 7px !important;\r\n  font-size: 0.52rem !important;\r\n  padding: 4px 7px !important;\r\n  scrollbar-width: none;\r\n}\r\n.eden-map-legend::-webkit-scrollbar { display: none; }\r\n.eden-map-legend span { flex-shrink: 0; white-space: nowrap; }\r\n\r\n.eden-minimap {\r\n  width: 90px !important;\r\n  height: 90px !important;\r\n  right: 4px !important;\r\n  bottom: 4px !important;\r\n  border-radius: 6px !important;\r\n}\r\n\r\n.global-game-clock { font-size: 0.68rem !important; padding: 4px 9px !important; }\r\n.eden-game-clock { font-size: 0.6rem !important; padding: 4px 7px !important; }\r\n.eden-mode-label { font-size: 0.56rem !important; flex-shrink: 0; gap: 3px !important; }\r\n.eden-mode-label input[type=\"range\"] { width: 68px !important; }\r\n.eden-speed-val { font-size: 0.58rem !important; }\r\n.eden-team-board { max-height: 150px !important; }\r\n\r\n/* Quick jump bar */\r\n.eden-quick-btn {\r\n  flex-shrink: 0;\r\n  font-size: 0.58rem !important;\r\n  padding: 6px 9px !important;\r\n  min-height: 30px;\r\n}\r\n.eden-quick-divider { height: 20px !important; margin: 0 3px !important; }\r\n\r\n/* Filter / search */\r\n.eden-filter-row { grid-template-columns: 1fr 1fr !important; gap: 4px !important; }\r\n.eden-filter-select { font-size: 0.6rem !important; min-height: 34px; width: 100% !important; }\r\n.eden-stats { font-size: 0.58rem !important; padding-right: 32px !important; }\r\n.eden-hover-info { font-size: 0.58rem !important; }\r\n.eden-selected-actions { flex-wrap: wrap !important; gap: 4px !important; }\r\n.eden-action-btn { min-height: 34px; flex: 1 1 auto; font-size: 0.6rem !important; }\r\n.eden-struct-row { min-height: 40px !important; padding: 6px 7px !important; }\r\n.eden-struct-list { max-height: none !important; }\r\n\r\n/* Season card / dataset */\r\n.eden-season-card { padding: 12px !important; }\r\n.eden-dataset-select { max-width: 130px; }\r\n.eden-coord-search-row { flex-wrap: nowrap; }\r\n.eden-coord-go-btn { padding: 6px 9px !important; min-height: var(--tap-min); }\r\n\r\n/* Help / guide panel */\r\n.eden-help-panel { padding: 9px !important; margin-top: 8px !important; }\r\n.eden-help-summary { font-size: 0.7rem !important; }\r\n.eden-guide-sec-label { max-width: 52px !important; }\r\n.eden-guide-step-title { font-size: 0.74rem !important; }\r\n.eden-guide-step-desc { font-size: 0.64rem !important; }\r\n.eden-guide-nav-row { flex-direction: column; gap: 4px; }\r\n.eden-guide-nav-btn { width: 100%; text-align: center; min-height: var(--tap-min); }\r\n\r\n/* ── 13. LOYALTY / EDEN LOYALTY TAB ──────────────────────── */\r\n.loyalty-title { font-size: 1.1rem !important; }\r\n.loyalty-desc { font-size: 0.7rem !important; }\r\n.loyalty-header { gap: 8px !important; margin-bottom: 0.6rem !important; }\r\n.loyalty-eden-link-btn { width: 100%; text-align: center; font-size: 0.66rem !important; }\r\n.loyalty-presets { padding: 7px 9px !important; gap: 5px !important; overflow-x: auto; flex-wrap: nowrap; scrollbar-width: none; }\r\n.loyalty-presets::-webkit-scrollbar { display: none; }\r\n.loyalty-preset-btn { font-size: 0.6rem !important; padding: 5px 8px !important; flex-shrink: 0; min-height: 32px; }\r\n.loyalty-sticky { padding: 9px 11px !important; border-radius: 11px !important; }\r\n.loyalty-sticky-stats { grid-template-columns: 1fr 1fr !important; }\r\n.loyalty-stat-value { font-size: 0.85rem !important; }\r\n.loyalty-calc-btn { font-size: 0.7rem !important; min-height: var(--tap-min); padding: 0 14px !important; }\r\n#loyaltySection .grid { gap: 9px !important; }\r\n#loyaltySection input, #loyaltySection select { font-size: 0.78rem !important; min-height: 38px; }\r\n#loyaltySection label { font-size: 0.7rem !important; }\r\n.loyalty-inputs > .p-5 { padding: 10px !important; }\r\n.loyalty-result-value { font-size: 0.96rem !important; }\r\n.loyalty-step-card-grid { gap: 5px 7px !important; }\r\n\r\n/* ── 14. VTS ADMIN / OCR TAB ──────────────────────────────── */\r\n/* Already covered by app.css @640px block.\r\n   Add any gap-fills here: */\r\n#ocrDashboardRoot .dash-main-grid[style*=\"1.2fr\"] {\r\n  grid-template-columns: 1fr !important;\r\n}\r\n#ocrDashboardRoot .dash-upload-zone.hidden { display: block !important; }\r\n#ocrDashboardRoot .dash-log-output { height: 110px; font-size: 0.68rem; }\r\n#ocrDashboardRoot .dash-modal { align-items: flex-end; padding: 0; }\r\n#ocrDashboardRoot .dash-modal-content {\r\n  max-height: 90vh;\r\n  border-radius: 1rem 1rem 0 0;\r\n  border-bottom: 0;\r\n  padding: 1.15rem;\r\n}\r\n\r\n/* ── 15. YOUTUBE TAB ──────────────────────────────────────── */\r\n#youtubeSection h2 { font-size: 0.92rem !important; letter-spacing: 0.05em !important; }\r\n#youtubeSection .mb-8, #youtubeSection > div {\r\n  padding: 10px !important;\r\n  margin-bottom: 12px !important;\r\n  border-radius: 12px !important;\r\n}\r\n#youtubeSection a { font-size: 0.6rem !important; padding: 5px 9px !important; }\r\n\r\n/* ── 16. COMMENTS SECTION ─────────────────────────────────── */\r\n#commentsSection { margin-top: 14px !important; border-radius: 12px !important; }\r\n#commentsSection h2 { font-size: 0.8rem !important; }\r\n#commentForm textarea, #commentForm input { font-size: 0.78rem !important; min-height: 38px; }\r\n#commentSubmitBtn { width: 100%; min-height: var(--tap-min); }\r\n.comment-avatar { width: 28px !important; height: 28px !important; min-width: 28px !important; font-size: 0.82rem !important; }\r\n.replies-container { margin-left: 0.75rem !important; padding-left: 0.6rem !important; }\r\n\r\n/* ── 17. UI UTILITIES ─────────────────────────────────────── */\r\n/* Scroll-to-top button */\r\n#scrollTopBtn {\r\n  bottom: calc(5rem + var(--safe-bottom)) !important;\r\n  right: 0.65rem !important;\r\n  width: 34px !important;\r\n  height: 34px !important;\r\n}\r\n\r\n/* Language select */\r\n#languageSelect { font-size: 0.8rem !important; padding-top: 2px !important; padding-bottom: 2px !important; padding-right: 28px !important; }\r\n.lang-select-wrapper { height: 32px !important; }\r\n.lang-select-wrapper > div { height: 32px !important; border-radius: 6px !important; }\r\n.global-game-clock { font-size: 0.75rem !important; padding: 4px 8px !important; height: 32px !important; display: flex !important; align-items: center !important; }\r\n.hero-search-input { font-size: 0.78rem !important; }\r\n.hero-search-input:focus { box-shadow: 0 0 0 3px rgba(59,130,246,0.18) !important; }\r\n.research-search-input:focus { box-shadow: 0 0 0 3px rgba(59,130,246,0.18) !important; }\r\n\r\n/* SEO footer */\r\n.seo-intro { font-size: 0.66rem !important; padding: 0 3px !important; margin-bottom: 0.75rem !important; }\r\n.site-footer { padding: 0.85rem 0.65rem 1rem !important; margin-top: 1rem !important; }\r\n.site-footer-desc { font-size: 0.64rem !important; }\r\n.site-footer-features { font-size: 0.6rem !important; }\r\n\r\n/* Theme toggle */\r\n[data-theme=\"light\"] #themeToggle { width: 30px !important; height: 30px !important; }\r\n\r\n/* Heroes tab header */\r\n.heroes-tab-header h2 { font-size: 1.1rem !important; }\r\n.heroes-tab-header p { font-size: 0.72rem !important; }\r\n\r\n/* ── 18. MICRO-INTERACTIONS ───────────────────────────────── */\r\n/* Spring feedback on all tappable elements */\r\n.tab-pill:active,\r\n.filter-pill:active,\r\n.hero-card:active,\r\n.generator-card:active,\r\nbutton:not([disabled]):active,\r\n.eden-tool-btn:active,\r\n.loyalty-preset-btn:active,\r\n.research-quick-btn:active,\r\n.hero-tab-season:active {\r\n  transform: scale(0.94) !important;\r\n  transition: transform 0.1s cubic-bezier(0.25, 1, 0.5, 1) !important;\r\n}\r\n\r\n/* Generator/combo action buttons — bigger spring */\r\n#generateCombosBtn:active,\r\n#generateRandomBtn:active,\r\n#downloadGeneratorBtn:active {\r\n  transform: scale(0.97) !important;\r\n}\r\n\r\n/* ── 19. LIGHT THEME OVERRIDES ────────────────────────────── */\r\n[data-theme=\"light\"] #tabNavScroll {\r\n  background: rgba(248,250,252,0.9) !important;\r\n  border-color: rgba(0,0,0,0.06) !important;\r\n}\r\n[data-theme=\"light\"] #comboFooterBar {\r\n  box-shadow: 0 -4px 20px rgba(0,0,0,0.12) !important;\r\n}\r\n[data-theme=\"light\"] .eden-sidebar {\r\n  box-shadow: 0 -6px 24px rgba(0,0,0,0.15) !important;\r\n}\r\n[data-theme=\"light\"] .hero-card:hover,\r\n[data-theme=\"light\"] .generator-card:hover {\r\n  box-shadow: 0 4px 18px rgba(0,0,0,0.12) !important;\r\n}\r\n\r\n/* ── 20. NARROW PHONE BREAKPOINTS ────────────────────────── */\r\n@media (max-width: 480px) {\r\n  /* 3 columns for very small phones */\r\n  #generatorHeroes, #availableHeroes {\r\n    grid-template-columns: repeat(3, 1fr) !important;\r\n  }\r\n  .hero-card img, .generator-card img { width: 52px !important; height: 52px !important; }\r\n  .hero-card span.text-xs, .generator-card span.text-xs { font-size: 0.58rem !important; }\r\n\r\n  .tab-pill { font-size: 0.63rem !important; padding: 0.38rem 0.48rem !important; }\r\n  .research-grid { grid-template-columns: repeat(3, 1fr) !important; }\r\n  .eden-tool-btn { padding: 7px 8px !important; font-size: 0.57rem !important; }\r\n  .eden-minimap { width: 78px !important; height: 78px !important; }\r\n  .eden-canvas-wrap, #edenMapCanvas { min-height: 44vh !important; }\r\n  .detail-stats-row { grid-template-columns: 1fr 1fr !important; }\r\n}\r\n\r\n@media (max-width: 360px) {\r\n  /* Extreme small — Galaxy S22 Ultra min width */\r\n  #appTitle { font-size: 1.35rem !important; }\r\n  .tab-pill { font-size: 0.58rem !important; padding: 0.35rem 0.42rem !important; }\r\n  #generatorHeroes, #availableHeroes {\r\n    grid-template-columns: repeat(3, 1fr) !important;\r\n    gap: 4px !important;\r\n  }\r\n  .research-grid { grid-template-columns: repeat(3, 1fr) !important; }\r\n  .combo-slot { width: 58px !important; height: 58px !important; }\r\n}\r\n\r\n/* 10.0.0 mobile flow refresh */\r\n@media (max-width: 768px) {\r\n  body {\r\n    padding: 8px !important;\r\n    background-attachment: scroll !important;\r\n  }\r\n\r\n  #app.app-shell {\r\n    width: 100% !important;\r\n    padding: 10px !important;\r\n    border-radius: 16px !important;\r\n  }\r\n\r\n  .command-header {\r\n    display: grid !important;\r\n    grid-template-columns: 1fr !important;\r\n    gap: 8px !important;\r\n    margin-bottom: 10px !important;\r\n  }\r\n\r\n  .command-brand,\r\n  .command-actions {\r\n    padding: 10px !important;\r\n    border-radius: 14px !important;\r\n  }\r\n\r\n  .version-ribbon {\r\n    justify-self: stretch !important;\r\n    font-size: 0.64rem !important;\r\n    padding: 7px 9px !important;\r\n  }\r\n\r\n  .command-logo {\r\n    grid-template-columns: 58px minmax(0, 1fr) !important;\r\n    -moz-column-gap: 10px !important;\r\n         column-gap: 10px !important;\r\n  }\r\n\r\n  .command-logo .main-logo {\r\n    width: 58px !important;\r\n    height: 58px !important;\r\n    border-radius: 13px !important;\r\n  }\r\n\r\n  .command-logo #appTitle {\r\n    font-size: clamp(1.45rem, 9vw, 2.05rem) !important;\r\n    line-height: 0.98 !important;\r\n    text-align: left !important;\r\n  }\r\n\r\n  .command-logo > div {\r\n    align-items: flex-start !important;\r\n  }\r\n\r\n  .command-logo > div p {\r\n    font-size: 0.58rem !important;\r\n    line-height: 1.15 !important;\r\n  }\r\n\r\n  .command-copy.seo-intro {\r\n    font-size: 0.68rem !important;\r\n    line-height: 1.45 !important;\r\n    margin: 0 !important;\r\n    padding: 0 !important;\r\n    text-align: left !important;\r\n  }\r\n\r\n  .command-actions {\r\n    flex-direction: column !important;\r\n    align-items: stretch !important;\r\n  }\r\n\r\n  .command-kicker {\r\n    align-self: stretch !important;\r\n    justify-content: center !important;\r\n    font-size: 0.6rem !important;\r\n    padding: 6px 8px !important;\r\n  }\r\n\r\n  .app-control-row {\r\n    justify-content: space-between !important;\r\n    gap: 6px !important;\r\n  }\r\n\r\n  .tool-nav-shell {\r\n    top: 6px !important;\r\n    margin-bottom: 10px !important;\r\n  }\r\n\r\n  .tool-nav-inner {\r\n    border-radius: 14px !important;\r\n    padding: 4px !important;\r\n    gap: 4px !important;\r\n  }\r\n\r\n  #tabNavScroll {\r\n    flex: 1 1 auto !important;\r\n    justify-content: flex-start !important;\r\n    width: auto !important;\r\n    margin-inline: 0 !important;\r\n    max-width: calc(100vw - 78px) !important;\r\n    gap: 4px !important;\r\n    padding: 1px !important;\r\n  }\r\n\r\n  .tab-scroll-btn {\r\n    width: 32px !important;\r\n    height: 32px !important;\r\n    border-radius: 10px !important;\r\n  }\r\n\r\n  .tab-pill {\r\n    min-height: 36px !important;\r\n    padding: 7px 9px !important;\r\n    font-size: 0.66rem !important;\r\n    gap: 5px !important;\r\n  }\r\n\r\n  .tab-pill svg {\r\n    width: 12px !important;\r\n    height: 12px !important;\r\n  }\r\n\r\n  #globalToggleRow {\r\n    margin-bottom: 9px !important;\r\n  }\r\n\r\n  #globalToggleRow label {\r\n    width: 100% !important;\r\n    justify-content: space-between !important;\r\n    border-radius: 12px !important;\r\n  }\r\n\r\n  #manualSection > .mb-6.p-4,\r\n  #generatorSection > .mb-6.p-4,\r\n  .research-control-deck,\r\n  .research-summary-card,\r\n  .loyalty-sticky,\r\n  #commentsSection {\r\n    border-radius: 13px !important;\r\n    padding: 10px !important;\r\n  }\r\n\r\n  #availableHeroes,\r\n  #generatorHeroes {\r\n    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;\r\n    gap: 7px !important;\r\n  }\r\n\r\n  .hero-card,\r\n  .generator-card {\r\n    min-height: 112px !important;\r\n    padding: 7px !important;\r\n    border-radius: 12px !important;\r\n  }\r\n\r\n  .hero-card img,\r\n  .generator-card img {\r\n    width: 58px !important;\r\n    height: 58px !important;\r\n    margin-bottom: 5px !important;\r\n  }\r\n\r\n  .hero-card span.text-xs,\r\n  .generator-card span.text-xs {\r\n    font-size: 0.58rem !important;\r\n    line-height: 1.15 !important;\r\n  }\r\n\r\n  #comboFooterBar {\r\n    bottom: 8px !important;\r\n    padding: 10px !important;\r\n    border-radius: 14px !important;\r\n  }\r\n\r\n  #comboButtonsRow {\r\n    grid-template-columns: repeat(4, minmax(0, 1fr)) !important;\r\n    gap: 5px !important;\r\n  }\r\n\r\n  #comboButtonsRow button {\r\n    min-height: 38px !important;\r\n    padding: 7px 4px !important;\r\n    font-size: 0.62rem !important;\r\n  }\r\n}\r\n\r\n/* 10.0.0 mobile HUD correction */\r\n.command-header {\r\n  padding: 9px !important;\r\n  border-radius: 8px !important;\r\n  clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px) !important;\r\n  background:\r\n    linear-gradient(135deg, rgba(34, 211, 238, 0.16), transparent 42%),\r\n    linear-gradient(315deg, rgba(251, 191, 36, 0.12), transparent 38%),\r\n    repeating-linear-gradient(90deg, rgba(148, 163, 184, 0.045) 0 1px, transparent 1px 30px),\r\n    rgba(3, 8, 18, 0.96) !important;\r\n}\r\n\r\n.command-brand,\r\n.command-actions {\r\n  background: transparent !important;\r\n  border: 0 !important;\r\n  box-shadow: none !important;\r\n}\r\n\r\n.command-brand {\r\n  gap: 7px !important;\r\n  padding: 0 !important;\r\n}\r\n\r\n.version-ribbon {\r\n  justify-self: start !important;\r\n  width: auto !important;\r\n  max-width: 100% !important;\r\n  padding: 5px 9px !important;\r\n  font-size: 0.56rem !important;\r\n  border-radius: 0 !important;\r\n  clip-path: polygon(7px 0, 100% 0, calc(100% - 7px) 100%, 0 100%) !important;\r\n}\r\n\r\n.command-logo {\r\n  grid-template-columns: 54px minmax(0, 1fr) !important;\r\n  -moz-column-gap: 9px !important;\r\n       column-gap: 9px !important;\r\n}\r\n\r\n.command-logo .main-logo {\r\n  width: 54px !important;\r\n  height: 54px !important;\r\n  border-radius: 8px !important;\r\n  transform: rotate(-1.5deg);\r\n}\r\n\r\n.command-logo #appTitle {\r\n  font-size: clamp(1.4rem, 8.2vw, 2rem) !important;\r\n  line-height: 0.92 !important;\r\n  text-align: left !important;\r\n}\r\n\r\n.command-logo > div p {\r\n  font-size: 0.55rem !important;\r\n}\r\n\r\n.command-copy.seo-intro {\r\n  display: none !important;\r\n}\r\n\r\n.command-actions {\r\n  padding: 7px !important;\r\n  height: auto !important;\r\n  min-height: 0 !important;\r\n  border: 1px solid rgba(103, 232, 249, 0.18) !important;\r\n  clip-path: polygon(9px 0, 100% 0, 100% calc(100% - 9px), calc(100% - 9px) 100%, 0 100%, 0 9px) !important;\r\n  background: rgba(2, 6, 14, 0.56) !important;\r\n}\r\n\r\n.command-kicker {\r\n  align-self: stretch !important;\r\n  border-radius: 0 !important;\r\n  clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%) !important;\r\n  font-size: 0.56rem !important;\r\n  color: #06121d !important;\r\n}\r\n\r\n.app-control-row {\r\n  justify-content: space-between !important;\r\n}\r\n\r\n.global-game-clock,\r\n.lang-select-wrapper > div,\r\n#themeToggle,\r\n#installAppBtn {\r\n  border-radius: 8px !important;\r\n}\r\n\r\n.tool-nav-inner {\r\n  border-radius: 8px !important;\r\n  clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px) !important;\r\n}\r\n\r\n.tab-pill {\r\n  border-radius: 0 !important;\r\n  clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%) !important;\r\n  font-size: 0.64rem !important;\r\n}\r\n\r\n.generator-selection-actions {\r\n  gap: 5px !important;\r\n}\r\n\r\n.selection-action-btn,\r\n#genSelectAllBtn,\r\n#genClearAllBtn {\r\n  min-height: 32px !important;\r\n  padding: 7px 9px !important;\r\n  border-radius: 0 !important;\r\n  clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%) !important;\r\n  color: #eaffff !important;\r\n  font-size: 0.56rem !important;\r\n  line-height: 1.05 !important;\r\n}\r\n\r\n#generatorSection .mb-6 > .flex.items-center.justify-between {\r\n  gap: 8px !important;\r\n  align-items: flex-start !important;\r\n}\r\n\r\n.filter-pill:not(.free-pill):not(.paid-pill),\r\n.heroes-filter-pill,\r\n.hero-tab-season,\r\n.tech-season-btn,\r\n.research-quick-btn,\r\n.loyalty-preset-btn {\r\n  border-radius: 0 !important;\r\n  clip-path: polygon(7px 0, 100% 0, calc(100% - 7px) 100%, 0 100%) !important;\r\n  border-color: rgba(103, 232, 249, 0.24) !important;\r\n  background:\r\n    linear-gradient(135deg, rgba(14, 165, 233, 0.14), rgba(15, 23, 42, 0.72)) !important;\r\n  color: #cde7f7 !important;\r\n}\r\n\r\n.filter-pill:not(.free-pill):not(.paid-pill):has(input:checked),\r\n.heroes-filter-pill.active,\r\n.hero-tab-season.active,\r\n.tech-season-btn.active,\r\n.research-quick-btn.active,\r\n.loyalty-preset-btn.active {\r\n  border-color: rgba(255, 255, 255, 0.34) !important;\r\n  background:\r\n    linear-gradient(135deg, #22d3ee, #5eead4 58%, #fbbf24) !important;\r\n  color: #06121d !important;\r\n}\r\n\r\n.research-card-max {\r\n  border-radius: 0 !important;\r\n  clip-path: polygon(5px 0, 100% 0, calc(100% - 5px) 100%, 0 100%) !important;\r\n  color: #e0f2fe !important;\r\n}\r\n\r\n.detail-skin-stage-track {\r\n  grid-template-columns: 1fr !important;\r\n  gap: 6px !important;\r\n}\r\n\r\n.detail-skin-stage {\r\n  padding: 7px 8px !important;\r\n}\r\n\r\n.detail-skin-attr-grid {\r\n  grid-template-columns: 1fr !important;\r\n}\r\n\r\n/* 10.0.0 mobile boot gate */\r\n.boot-splash {\r\n  justify-content: center !important;\r\n  gap: 18px !important;\r\n}\r\n\r\n.boot-atmosphere {\r\n  background-size: auto, 82px 108px, 92px 118px, 36px 36px, 36px 36px, auto !important;\r\n}\r\n\r\n.perspective-container {\r\n  width: min(92vw, 420px) !important;\r\n  height: min(68vh, 560px) !important;\r\n  min-height: 390px;\r\n  border: 1px solid rgba(103, 232, 249, 0.18);\r\n  clip-path: polygon(18px 0, 100% 0, 100% calc(100% - 18px), calc(100% - 18px) 100%, 0 100%, 0 18px);\r\n  background: rgba(2, 6, 14, 0.62);\r\n}\r\n\r\n.door {\r\n  width: 50.5% !important;\r\n  height: 100% !important;\r\n}\r\n\r\n.door::before {\r\n  inset: 28px 14px !important;\r\n}\r\n\r\n.door-panel-lines {\r\n  inset: 58px 18px !important;\r\n}\r\n\r\n.boot-halo {\r\n  top: 18px !important;\r\n  width: 58px !important;\r\n  height: 14px !important;\r\n}\r\n\r\n.door-wing {\n  top: 46px !important;\n  width: 330px !important;\n  height: 292px !important;\n  opacity: 0.94 !important;\n  filter:\r\n    drop-shadow(0 0 13px color-mix(in srgb, var(--wing-secondary) 66%, transparent))\r\n    drop-shadow(0 0 26px color-mix(in srgb, var(--wing-hot) 28%, transparent)) !important;\r\n}\r\n\r\n.door-wing-left {\n  right: -86px !important;\n}\n\n.door-wing-right {\n  top: 24px !important;\n  left: -92px !important;\n  width: 310px !important;\n  height: 326px !important;\n}\n\r\n.door-wing span {\r\n  height: max(7px, calc(var(--feather-h, 14px) * 0.66)) !important;\r\n}\r\n\r\n.door-wing::before {\r\n  height: 16% !important;\r\n}\r\n\r\n.door-wing::after {\r\n  opacity: 0.32 !important;\r\n}\r\n\r\n.door-emblem {\r\n  width: 104px !important;\r\n  height: 104px !important;\r\n  font-size: 0.86rem !important;\r\n}\r\n\r\n.door-emblem-ring {\r\n  inset: 10px !important;\r\n}\r\n\r\n.door-faction {\r\n  bottom: 42px !important;\r\n  font-size: 0.54rem !important;\r\n  padding: 5px 8px !important;\r\n}\r\n\r\n.door-left .door-faction {\r\n  right: 16px !important;\r\n}\r\n\r\n.door-right .door-faction {\r\n  left: 16px !important;\r\n}\r\n\r\n.gate-lock {\r\n  top: 48% !important;\r\n  width: 76px !important;\r\n  height: 76px !important;\r\n}\r\n\r\n.loading-status-container {\r\n  width: min(88vw, 390px) !important;\r\n  max-width: none !important;\r\n  margin-top: 0 !important;\r\n  padding: 14px 16px !important;\r\n}\r\n\r\n.boot-kicker {\r\n  font-size: 0.5rem !important;\r\n  margin-bottom: 6px !important;\r\n}\r\n\r\n.loading-title {\r\n  font-size: 1rem !important;\r\n}\r\n\r\n.boot-sub {\r\n  font-size: 0.52rem !important;\r\n  margin-bottom: 8px !important;\r\n}\r\n\r\n.boot-status-text {\r\n  font-size: 0.62rem !important;\r\n  margin-bottom: 8px !important;\r\n}\r\n\r\n.boot-progress {\r\n  height: 5px !important;\r\n}\r\n"
__vite__updateStyle(__vite__id, __vite__css)
import.meta.hot.accept()
import.meta.hot.prune(() => __vite__removeStyle(__vite__id))